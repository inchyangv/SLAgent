FROM python:3.11-slim

WORKDIR /app

COPY pyproject.toml .
COPY gateway/ gateway/
COPY shared/ shared/
COPY buyer_agent/ buyer_agent/
COPY facilitator/ facilitator/
COPY seller/ seller/

RUN pip install --no-cache-dir -e .
RUN mkdir -p data

EXPOSE 8000
CMD uvicorn gateway.app.main:app --host 0.0.0.0 --port ${PORT:-8000}
