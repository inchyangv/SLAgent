# Single source of truth for local/demo configuration.
#
# Usage:
#   1) cp .env.example .env
#   2) Fill the blanks (keys/addresses)
#   3) Start services (gateway/seller/scripts) — they auto-load repo-root .env

# ── Network (SKALE Hackathon: BITE v2 Sandbox 2) ─────────────────────────────
CHAIN_ID=103698795
CHAIN_RPC_URL=https://base-sepolia-testnet.skalenodes.com/v1/bite-v2-sandbox
EXPLORER_URL=https://base-sepolia-testnet-explorer.skalenodes.com:10032

# ── Token (predeployed USDC) ────────────────────────────────────────────────
PAYMENT_TOKEN_ADDRESS=0xc4083B1E81ceb461Ccef3FDa8A9F24F0d764B6D8
SLA_TOKEN_NAME=USDC
# USDC on this chain returns version() == "" (empty string)
SLA_TOKEN_VERSION=

# Foundry deploy helper (optional but convenient)
RPC_URL=https://base-sepolia-testnet.skalenodes.com/v1/bite-v2-sandbox
TOKEN_ADDRESS=0xc4083B1E81ceb461Ccef3FDa8A9F24F0d764B6D8
PRIVATE_KEY=

# ── Contracts (current deployment on SKALE BITE v2 Sandbox 2) ──────────────
SETTLEMENT_CONTRACT_ADDRESS=0xd5FBcF82364865E2477Aae988A3C3232Fae77756

# ── Gateway ─────────────────────────────────────────────────────────────────
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8000
SELLER_UPSTREAM_URL=http://localhost:8001
GATEWAY_URL=http://localhost:8000
SELLER_URL=http://localhost:8001

# Required for live-chain tx submission (gateway settle/disputes signer).
# NOTE: current implementation uses the BUYER EOA as the deposit payer.
GATEWAY_PRIVATE_KEY=

# Optional: for nicer receipts/settlement params (must be a valid EVM address)
SELLER_ADDRESS=0x2222222222222222222222222222222222222222

# Payment gating mode:
# - hmac: easiest demo (no signature)
# - x402: EIP-712 signed payment header verification
PAYMENT_MODE=hmac

# Enable demo-only features (dashboard, /v1/demo/*, relaxed CORS).
DEMO_MODE=true
DEMO_CORS=true

# Optional persistence
RECEIPT_DB_PATH=data/receipts.db
EVENT_DB_PATH=data/events.db

# ── Seller (Gemini) ─────────────────────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Set true to disable live LLM calls (deterministic fallback responses)
SELLER_FALLBACK=false

# Optional: Gemini-driven policy layer (gateway side)
# - LLM_POLICY_ENABLED: SLA adjudication + payout recommendation
# - LLM_NEGOTIATION_ENABLED: mandate/price negotiation suggestion
LLM_POLICY_ENABLED=false
LLM_NEGOTIATION_ENABLED=false

# Optional: seller signing for receipt attestation
SELLER_PRIVATE_KEY=

# ── Buyer (only needed for PAYMENT_MODE=x402) ───────────────────────────────
BUYER_ADDRESS=0x1111111111111111111111111111111111111111
BUYER_PRIVATE_KEY=

# ── Single-secret demo mode (optional) ──────────────────────────────────────
# Provide ONE secret and role keys can be derived automatically.
# DEMO_SECRET_MODE=private_key  -> all roles share one EOA (simplest)
# DEMO_SECRET_MODE=mnemonic     -> derive role keys per role (recommended)
DEMO_SECRET_MODE=
DEMO_PRIVATE_KEY=
DEMO_MNEMONIC=
