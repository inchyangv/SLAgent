# Single source of truth for local/demo configuration.
#
# Usage:
#   1) cp .env.example .env
#   2) Fill the blanks (keys/addresses)
#   3) Start services (gateway/seller/scripts) - they auto-load repo-root .env

# --- Chain (Ethereum Sepolia) ---
CHAIN_ID=11155111
CHAIN_RPC_URL=https://rpc.sepolia.org
EXPLORER_URL=https://sepolia.etherscan.io
# Optional network-specific overrides used by `scripts/demo_one_command.py --network sepolia`
SEPOLIA_RPC_URL=
SEPOLIA_EXPLORER_URL=

# --- Token + settlement (deploy your mock USDT first) ---
PAYMENT_TOKEN_ADDRESS=
SLA_TOKEN_NAME="Tether USD"
SLA_TOKEN_SYMBOL=USDT
# Local mock token keeps version() empty, so leave this blank.
SLA_TOKEN_VERSION=
SETTLEMENT_CONTRACT_ADDRESS=
SEPOLIA_PAYMENT_TOKEN_ADDRESS=
SEPOLIA_SETTLEMENT_CONTRACT_ADDRESS=

# --- Gateway/service endpoints ---
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8000
SELLER_UPSTREAM_URL=http://localhost:8001
GATEWAY_URL=http://localhost:8000
SELLER_URL=http://localhost:8001
SELLER_PORT=8001
WDK_SERVICE_URL=http://localhost:3100
WDK_PORT=3100
WDK_CHAIN_NAME=ethereum
WDK_EVM_RPC_URL=https://rpc.sepolia.org
WDK_USDT_ADDRESS=
WDK_SETTLEMENT_ADDRESS=
SEPOLIA_WDK_RPC_URL=
SEPOLIA_WDK_USDT_ADDRESS=
SEPOLIA_WDK_SETTLEMENT_ADDRESS=
WDK_SEED_PHRASE=
BUYER_WDK_ACCOUNT_INDEX=0
GATEWAY_WDK_ACCOUNT_INDEX=2

# --- Role addresses (set to match keys, or use DEMO_SECRET_MODE below) ---
BUYER_ADDRESS=
SELLER_ADDRESS=
GATEWAY_ADDRESS=
RESOLVER_ADDRESS=

# --- Role private keys (required for on-chain settlement) ---
BUYER_PRIVATE_KEY=
SELLER_PRIVATE_KEY=
GATEWAY_PRIVATE_KEY=
RESOLVER_PRIVATE_KEY=

# --- Demo single-secret mode (optional) ---
# If set, role keys/addresses are derived automatically.
# DEMO_SECRET_MODE=private_key  -> all roles share one EOA (simplest)
# DEMO_SECRET_MODE=mnemonic     -> derive per-role keys (recommended)
DEMO_SECRET_MODE=
DEMO_PRIVATE_KEY=
DEMO_MNEMONIC=

# --- Seller (Gemini) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
# Set true to disable live LLM calls (deterministic fallback responses)
SELLER_FALLBACK=false

# --- Optional gateway LLM policy/negotiation helpers ---
LLM_POLICY_ENABLED=false
LLM_NEGOTIATION_ENABLED=false

# --- Demo helpers ---
# DEMO_INSTANT_PAYOUT opens+resolves a dispute to make payout visible immediately.
DEMO_MODE=true
DEMO_CORS=true
DEMO_INSTANT_PAYOUT=true

# --- Persistence ---
RECEIPT_DB_PATH=data/receipts.db

# --- Optional ERC-8004 integration ---
ORCHESTRATOR_CONTRACT_ADDRESS=

# --- Foundry deploy helper (optional) ---
RPC_URL=https://rpc.sepolia.org
TOKEN_ADDRESS=
PRIVATE_KEY=
DISPUTE_WINDOW_SECONDS=60
BOND_AMOUNT=10000
MINT_TO_GATEWAY=1000000000
APPROVE_MAX=true
