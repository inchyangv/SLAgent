# Single source of truth for local/demo configuration.
#
# Usage:
#   1) cp .env.example .env
#   2) Fill the blanks (keys/addresses)
#   3) Start services (gateway/seller/scripts) - they auto-load repo-root .env

# --- Chain (SKALE Base Sepolia / BITE v2 Sandbox 2) ---
CHAIN_ID=103698795
CHAIN_RPC_URL=https://base-sepolia-testnet.skalenodes.com/v1/bite-v2-sandbox
EXPLORER_URL=https://base-sepolia-testnet-explorer.skalenodes.com:10032

# --- Token + settlement (USDC predeployed) ---
PAYMENT_TOKEN_ADDRESS=0xc4083B1E81ceb461Ccef3FDa8A9F24F0d764B6D8
SLA_TOKEN_NAME=USDC
# On this chain USDC returns version() == "" (empty string)
SLA_TOKEN_VERSION=
SETTLEMENT_CONTRACT_ADDRESS=0xd5FBcF82364865E2477Aae988A3C3232Fae77756

# --- Gateway/service endpoints ---
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8000
SELLER_UPSTREAM_URL=http://localhost:8001
GATEWAY_URL=http://localhost:8000
SELLER_URL=http://localhost:8001
SELLER_PORT=8001

# --- Payment gating mode ---
# hmac: easiest local demo (no signature)
# x402: EIP-712 payment header verification
PAYMENT_MODE=hmac

# --- Role addresses (set to match keys, or use DEMO_SECRET_MODE below) ---
BUYER_ADDRESS=
SELLER_ADDRESS=
GATEWAY_ADDRESS=
RESOLVER_ADDRESS=

# --- Role private keys (required for x402 + on-chain settlement) ---
BUYER_PRIVATE_KEY=
SELLER_PRIVATE_KEY=
GATEWAY_PRIVATE_KEY=
RESOLVER_PRIVATE_KEY=

# --- Demo single-secret mode (optional) ---
# If set, role keys/addresses are derived automatically.
# DEMO_SECRET_MODE=private_key  -> all roles share one EOA (simplest)
# DEMO_SECRET_MODE=mnemonic     -> derive per-role keys (recommended)
DEMO_SECRET_MODE=
DEMO_PRIVATE_KEY=
DEMO_MNEMONIC=

# --- Seller (Gemini) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
# Set true to disable live LLM calls (deterministic fallback responses)
SELLER_FALLBACK=false

# --- Optional gateway LLM policy/negotiation helpers ---
LLM_POLICY_ENABLED=false
LLM_NEGOTIATION_ENABLED=false

# --- Demo helpers ---
# DEMO_INSTANT_PAYOUT opens+resolves a dispute to make payout visible immediately.
DEMO_MODE=true
DEMO_CORS=true
DEMO_INSTANT_PAYOUT=true

# --- Persistence ---
RECEIPT_DB_PATH=data/receipts.db

# --- Optional ERC-8004 integration ---
ORCHESTRATOR_CONTRACT_ADDRESS=

# --- Foundry deploy helper (optional) ---
RPC_URL=https://base-sepolia-testnet.skalenodes.com/v1/bite-v2-sandbox
TOKEN_ADDRESS=0xc4083B1E81ceb461Ccef3FDa8A9F24F0d764B6D8
PRIVATE_KEY=
DISPUTE_WINDOW_SECONDS=60
BOND_AMOUNT=10000
MINT_TO_GATEWAY=1000000000
APPROVE_MAX=true
