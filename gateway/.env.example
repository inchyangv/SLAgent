# Gateway configuration
SELLER_UPSTREAM_URL=http://localhost:8001
# Seller's EVM address for on-chain settlement (required for live chain mode)
SELLER_ADDRESS=0x_seller_evm_address_here
# Buyer's default EVM address (optional, buyer sends via x402 header)
BUYER_ADDRESS=
CHAIN_ID=1444673419
# SKALE Europa Testnet (juicy-low-small-testnet)
CHAIN_RPC_URL=https://testnet.skalenodes.com/v1/juicy-low-small-testnet
SETTLEMENT_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
PAYMENT_TOKEN_ADDRESS=0x0000000000000000000000000000000000000000
GATEWAY_PRIVATE_KEY=0x_your_gateway_private_key_here

# Payment mode: "hmac" (local dev) or "x402" (real EIP-3009 signatures)
PAYMENT_MODE=hmac

# Receipt persistence: set to enable SQLite storage (empty = in-memory only)
RECEIPT_DB_PATH=data/receipts.db
